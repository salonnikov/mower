#pragma once

#define WIFI_SSID "имя_твоей_точки"     // имя Wi-Fi сети (SSID)
#define WIFI_PASS "пароль_от_сети"      // пароль Wi-Fi

#define MQTT_HOST "192.168.1.10"        // IP твоего MQTT-брокера (Home Assistant)
#define MQTT_PORT 1883                  // порт брокера
#define MQTT_USER ""                    // логин брокера ("" если без авторизации)
#define MQTT_PASS ""                    // пароль брокера ("" если без авторизации)
